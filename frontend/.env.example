# ── SafeRaipur frontend env ─────────────────────────────────────────
# Copy to .env for local dev. On Vercel: Project → Settings → Environment Variables.

# Supabase (Dashboard → Settings → API). The ANON key is safe for browsers.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# OpenRouteService — free key from https://openrouteservice.org/dev/#/signup
# (2,000 requests/day). Optional: without it, routing falls back to the
# public OSRM demo server (fine for demos, not guaranteed uptime).
VITE_ORS_API_KEY=
